---
layout: base.njk
title: Free Case Evaluation
description: "Get a free case evaluation from Flake & Flake Attorneys. Henderson & Las Vegas, NV."
---

<section class="relative pt-24 pb-16 px-8 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <span class="text-on-tertiary-container font-bold tracking-[0.2em] uppercase text-xs mb-6 block">Case Evaluation</span>
    <h1 class="font-headline text-5xl md:text-6xl font-light tracking-tighter text-primary mb-8">
      Free Case <span class="italic">Evaluation</span>
    </h1>
    <p class="text-on-surface-variant text-xl">Tell us about your situation and we'll provide an honest assessment.</p>
  </div>
</section>

<section class="py-20 px-8 bg-surface-container-low">
  <div class="max-w-3xl mx-auto">
    <form class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="text-xs font-bold uppercase tracking-widest text-secondary block mb-2">First Name</label>
          <input type="text" class="w-full bg-surface-container-highest border-0 text-primary p-4 focus:ring-1 focus:ring-primary rounded" placeholder="First name" />
        </div>
        <div>
          <label class="text-xs font-bold uppercase tracking-widest text-secondary block mb-2">Last Name</label>
          <input type="text" class="w-full bg-surface-container-highest border-0 text-primary p-4 focus:ring-1 focus:ring-primary rounded" placeholder="Last name" />
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="text-xs font-bold uppercase tracking-widest text-secondary block mb-2">Email</label>
          <input type="email" class="w-full bg-surface-container-highest border-0 text-primary p-4 focus:ring-1 focus:ring-primary rounded" placeholder="your@email.com" />
        </div>
        <div>
          <label class="text-xs font-bold uppercase tracking-widest text-secondary block mb-2">Phone</label>
          <input type="tel" class="w-full bg-surface-container-highest border-0 text-primary p-4 focus:ring-1 focus:ring-primary rounded" placeholder="(702) 555-0000" />
        </div>
      </div>
      
      <div>
        <label class="text-xs font-bold uppercase tracking-widest text-secondary block mb-2">Type of Case</label>
        <select class="w-full bg-surface-container-highest border-0 text-on-surface p-4 focus:ring-1 focus:ring-primary rounded">
          <option>Select</option>
          <option>Estate Planning</option>
          <option>Probate</option>
          <option>Personal Injury</option>
          <option>Medical Malpractice</option>
          <option>FTCA / VA Malpractice</option>
          <option>Business Law</option>
          <option>Contract Dispute</option>
          <option>Other</option>
        </select>
      </div>
      
      <div>
        <label class="text-xs font-bold uppercase tracking-widest text-secondary block mb-2">Describe Your Situation</label>
        <textarea rows="6" class="w-full bg-surface-container-highest border-0 text-primary p-4 focus:ring-1 focus:ring-primary rounded" placeholder="Please describe your legal matter..."></textarea>
      </div>
      
      <button type="submit" class="w-full bg-primary text-on-primary py-5 font-label font-bold uppercase text-sm tracking-widest hover:bg-primary-container transition-all rounded-sm shadow-lg hover:-translate-y-1 duration-300">Submit Case Evaluation</button>
      
      <p class="text-xs text-on-surface-variant text-center">Your information is confidential. Submitting this form does not create an attorney-client relationship.</p>
    </form>
  </div>
</section>