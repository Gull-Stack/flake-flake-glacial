---
layout: base.njk
---
<!-- Hero -->
<section class="relative pt-24 pb-24 px-8 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <span class="text-on-tertiary-container font-bold tracking-[0.2em] uppercase text-xs mb-6 block">{{ serviceLabel }}</span>
    <h1 class="font-headline text-5xl md:text-6xl font-light tracking-tighter text-primary leading-[0.95] mb-8">{{ heroHeadline }}</h1>
    <p class="text-on-surface-variant text-lg md:text-xl max-w-3xl leading-relaxed font-light">{{ heroSubheadline }}</p>
  </div>
</section>

<!-- Problem Section -->
{% if problems %}
<section class="py-20 px-8 bg-surface-container-low">
  <div class="max-w-5xl mx-auto">
    <span class="text-secondary font-bold tracking-[0.2em] uppercase text-xs mb-6 block">The Problem</span>
    <h2 class="font-headline text-4xl font-medium text-primary mb-12">Does This Sound Familiar?</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {% for problem in problems %}
      <div class="p-8 bg-surface-container hover:bg-surface-container-high transition-colors rounded-lg shadow-sm">
        <h3 class="text-lg font-bold text-primary mb-3">{{ problem.title }}</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">{{ problem.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Solution / Content Section -->
<section class="py-20 px-8 bg-surface">
  <div class="max-w-5xl mx-auto">
    <span class="text-secondary font-bold tracking-[0.2em] uppercase text-xs mb-6 block">The Solution</span>
    <h2 class="font-headline text-4xl font-medium text-primary mb-8">{{ solutionHeadline }}</h2>
    <div class="text-on-surface-variant text-lg leading-relaxed space-y-6 max-w-3xl">
      {{ content | safe }}
    </div>
  </div>
</section>

<!-- Services List -->
{% if servicesList %}
<section class="py-20 px-8 bg-surface-container-low">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-headline text-3xl font-medium text-primary mb-12">What We Handle</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {% for item in servicesList %}
      <div class="flex items-start gap-4 p-6 bg-surface-container-highest rounded-lg">
        <span class="material-symbols-outlined text-on-tertiary-container text-xl mt-1">check_circle</span>
        <span class="text-on-surface text-sm font-medium">{{ item }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Attorney -->
<section class="py-20 px-8 bg-surface">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-headline text-3xl font-medium text-primary mb-8">Your Attorney</h2>
    <div class="flex items-center gap-6 p-8 border-l-4 border-on-tertiary-container bg-surface-container/50 rounded-lg">
      <span class="material-symbols-outlined text-on-tertiary-container text-3xl">verified</span>
      <div>
        <h3 class="font-bold text-xl text-primary">{{ attorney }}</h3>
        <p class="text-on-surface-variant text-sm">{{ attorneyTitle }}</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
{% if faqs %}
<section class="py-20 px-8 bg-surface-container-low">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-headline text-3xl font-medium text-primary mb-12">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {% for faq in faqs %}
      <details class="group bg-surface-container-highest p-6 cursor-pointer rounded-lg">
        <summary class="flex justify-between items-center font-bold text-primary">
          {{ faq.q }}
          <span class="material-symbols-outlined text-secondary group-open:rotate-45 transition-transform">add</span>
        </summary>
        <p class="mt-4 text-on-surface-variant text-sm leading-relaxed">{{ faq.a }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- CTA -->
<section class="py-24 px-8 text-center bg-surface">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-headline text-4xl font-medium text-primary mb-6">{{ ctaHeadline | default("Ready to Take Action?") }}</h2>
    <p class="text-on-surface-variant text-lg mb-10">Schedule a free consultation to discuss your case.</p>
    <a href="/contact/" class="inline-block bg-primary text-on-primary px-10 py-5 font-label font-bold uppercase text-sm tracking-widest hover:bg-primary-container transition-all rounded-sm shadow-lg hover:-translate-y-1 duration-300">
      Free Consultation
    </a>
  </div>
</section>