<!DOCTYPE html>
<html class="light" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{{ title }} | Flake & Flake Attorneys at Law</title>
<meta name="description" content="{{ description | default('Flake & Flake Attorneys at Law — Estate Planning, Probate, Personal Injury, and Federal Civil Litigation in Henderson & Las Vegas, Nevada.') }}"/>
<meta property="og:title" content="{{ title }} | Flake & Flake"/>
<meta property="og:description" content="{{ description | default('Plan for the inevitable and recover from the unexpected.') }}"/>
<meta property="og:type" content="website"/>
<meta property="og:url" content="https://flakeandflake.com{{ page.url }}"/>
<link rel="canonical" href="https://flakeandflake.com{{ page.url }}"/>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://flakeandflake.com/"
    }
    {% if page.url != "/" %}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": "{{ title }}",
        "item": "https://flakeandflake.com{{ page.url }}"
      }
    {% endif %}
  ]
}
</script>

<link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Manrope:wght@200..800&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
tailwind.config = {
  darkMode: "class",
  theme: {
    extend: {
      colors: {
        "surface-variant": "#e1e3e4",
        "on-surface": "#191c1d",
        "secondary-fixed": "#e0e3e5",
        "inverse-surface": "#2e3132",
        "secondary": "#5b5f61",
        "on-background": "#191c1d",
        "surface-tint": "#456083",
        "surface": "#f8fafb",
        "error-container": "#ffdad6",
        "on-error": "#ffffff",
        "surface-dim": "#d8dadb",
        "error": "#ba1a1a",
        "on-tertiary-container": "#bd8856",
        "tertiary-container": "#442400",
        "on-tertiary-fixed-variant": "#663e12",
        "on-primary-fixed": "#001c38",
        "on-tertiary": "#ffffff",
        "background": "#f8fafb",
        "on-surface-variant": "#43474e",
        "inverse-on-surface": "#eff1f2",
        "secondary-container": "#e0e3e5",
        "tertiary-fixed": "#ffdcbf",
        "tertiary-fixed-dim": "#f6bb84",
        "on-secondary": "#ffffff",
        "on-primary-container": "#7a95bb",
        "surface-container-highest": "#e1e3e4",
        "tertiary": "#271200",
        "primary": "#001831",
        "on-error-container": "#93000a",
        "primary-fixed": "#d3e4ff",
        "secondary-fixed-dim": "#c4c7c9",
        "outline-variant": "#c3c6cf",
        "surface-container": "#eceeef",
        "primary-container": "#0d2d4d",
        "surface-container-lowest": "#ffffff",
        "on-secondary-fixed": "#191c1e",
        "on-secondary-fixed-variant": "#444749",
        "on-secondary-container": "#616567",
        "outline": "#74777f",
        "inverse-primary": "#adc8f0",
        "surface-bright": "#f8fafb",
        "on-primary-fixed-variant": "#2c486a",
        "surface-container-low": "#f2f4f5",
        "primary-fixed-dim": "#adc8f0",
        "on-primary": "#ffffff",
        "surface-container-high": "#e6e8e9",
        "on-tertiary-fixed": "#2d1600"
      },
      fontFamily: {
        "headline": ["Newsreader"],
        "body": ["Manrope"],
        "label": ["Manrope"]
      },
      borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
    },
  },
}
</script>
<style>
.material-symbols-outlined {
  font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
}
.editorial-shadow {
  box-shadow: 0 24px 48px -12px rgba(0, 24, 49, 0.06);
}
.glass-panel {
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.liquid-glass-card {
  background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.04) 50%, rgba(255,255,255,0.08) 100%);
  backdrop-filter: blur(20px) saturate(1.4);
  -webkit-backdrop-filter: blur(20px) saturate(1.4);
  border: 1px solid rgba(255,255,255,0.18);
  box-shadow: 
    0 8px 32px rgba(0,0,0,0.12),
    inset 0 1px 0 rgba(255,255,255,0.25),
    inset 0 -1px 0 rgba(255,255,255,0.05);
  transition: all 0.3s ease;
}
.liquid-glass-card:hover {
  background: linear-gradient(135deg, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.12) 100%);
  border-color: rgba(255,255,255,0.28);
  box-shadow: 
    0 12px 40px rgba(0,0,0,0.16),
    inset 0 1px 0 rgba(255,255,255,0.35),
    inset 0 -1px 0 rgba(255,255,255,0.08);
  transform: translateY(-2px);
}
.liquid-glass-icon {
  background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0.06) 100%);
  backdrop-filter: blur(16px) saturate(1.3);
  -webkit-backdrop-filter: blur(16px) saturate(1.3);
  border: 1px solid rgba(255,255,255,0.22);
  box-shadow: 
    0 4px 16px rgba(0,0,0,0.1),
    inset 0 1px 0 rgba(255,255,255,0.3);
}
</style>
</head>
<body class="bg-surface text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">

{% include "header.njk" %}

<main>
{{ content | safe }}
</main>

{% include "footer.njk" %}

</body>
</html>
